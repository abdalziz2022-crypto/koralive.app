# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
# VITE environment variables for football API
VITE_RAPID_API_KEY=
VITE_FOOTBALL_DATA_KEY=
VITE_FOOTBALL_DATA_BASE=https://api.football-data.org/v4
VITE_API_KEY=
VITE_API_BASE_URL=https://v3.football.api-sports.io
VITE_API_FOOTBALL_KEY=
VITE_API_FOOTBALL_BASE=https://v3.football.api-sports.io

# FIREBASE_SERVICE_ACCOUNT_KEY: Required for secure backend Firebase Admin SDK access.
# If you need background jobs (like match sync engines) to run on the server, you MUST
# generate a Service Account Key in the Firebase Console and paste its JSON contents here.
FIREBASE_SERVICE_ACCOUNT_KEY=
